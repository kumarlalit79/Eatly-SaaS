### [NEW] `src/hooks/useAuth.ts`

TanStack Query mutations for auth:

```typescript
// useMutation hooks:
export const useLogin = () => useMutation({
  mutationFn: (data: { email: string; password: string }) =>
    api.post('/auth/login', data),
  onSuccess: (res) => {
    useAuthStore.getState().setAuth(res.data.token, res.data.user, res.data.subscription);
    // navigate to /dashboard or /onboarding
  }
});

export const useSignup = () => useMutation({ ... });
export const useGoogleAuth = () => useMutation({ ... });
export const useForgotPassword = () => useMutation({ ... });
```

